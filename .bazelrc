# Common Bazel flags

# Enable Bzlmod (default in Bazel 7, explicit for clarity)
common --enable_bzlmod

# Forward JAVA_HOME from the calling shell into Bazel.
# --repo_env  : used during repository rule evaluation (local_jdk detection)
# --action_env: used during build action execution (javac, etc.)
# With mise/sdkman/asdf, JAVA_HOME is set by the shell — these flags pass it through.
build --repo_env=JAVA_HOME
build --action_env=JAVA_HOME

# Use a local disk cache to speed up rebuilds
build --disk_cache=~/.cache/bazel-disk

# Show test output on failure
test --test_output=errors

# Improve error output
build --verbose_failures
